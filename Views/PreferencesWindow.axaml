<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ColorPicker"
        xmlns:models="clr-namespace:LabelAva.Models"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="450"
        x:Class="LabelAva.Views.PreferencesWindow"
        Title="首选项"
        Width="500" Height="450"
        Background="{DynamicResource SystemChromeMediumLowBrush}"
        TransparencyLevelHint="None"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    
    <DockPanel Margin="16">

        <!-- TabControl：快捷键页签 -->
        <TabControl>
            <!-- 快捷键页签 -->
            <TabItem Header="快捷键">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12" Spacing="8">
                        <!-- 列标题 -->
                        <Border Background="#FCFCFC" CornerRadius="8" Padding="12" Margin="0,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="设置项" FontWeight="SemiBold" Foreground="#AAA"/>
                                <TextBlock Grid.Column="2" Text="主要" HorizontalAlignment="Center" Foreground="#AAA"/>
                                <TextBlock Grid.Column="4" Text="次要" HorizontalAlignment="Center" Foreground="#AAA"/>
                            </Grid>
                        </Border>

                        <!-- 导航设置组 -->
                        <Border Background="#F9F9F9" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="导航" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="在树状视图中上下移动" FontSize="12" Foreground="#666" TextWrapping="Wrap" Margin="0,-4,0,4"/>

                                <!-- 上导航 -->
                                <Grid RowDefinitions="Auto">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="上一个标记" VerticalAlignment="Center"/>
                                    <Button x:Name="NavigateUpButton" Grid.Row="0" Grid.Column="2"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="8,6" Click="OnNavigateUpClick">
                                        <TextBlock x:Name="NavigateUpText" Text="方向键上" Foreground="#999"/>
                                    </Button>
                                    <Button x:Name="NavigateUpSecondaryButton" Grid.Row="0" Grid.Column="4"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="8,6" Click="OnNavigateUpSecondaryClick">
                                        <TextBlock x:Name="NavigateUpSecondaryText" Text="未设置" Foreground="#999"/>
                                    </Button>
                                </Grid>

                                <!-- 下导航 -->
                                <Grid RowDefinitions="Auto" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="下一个标记" VerticalAlignment="Center"/>
                                    <Button x:Name="NavigateDownButton" Grid.Row="0" Grid.Column="2"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="8,6" Click="OnNavigateDownClick">
                                        <TextBlock x:Name="NavigateDownText" Text="方向键下" Foreground="#999"/>
                                    </Button>
                                    <Button x:Name="NavigateDownSecondaryButton" Grid.Row="0" Grid.Column="4"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="8,6" Click="OnNavigateDownSecondaryClick">
                                        <TextBlock x:Name="NavigateDownSecondaryText" Text="未设置" Foreground="#999"/>
                                    </Button>
                                </Grid>

                                <Grid RowDefinitions="Auto">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="上一张图片" VerticalAlignment="Center"/>
                                    <Button x:Name="PageUpButton" Grid.Row="0" Grid.Column="2"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="8,6" Click="OnPageUpClick">
                                        <TextBlock x:Name="PageUpText" Text="PageUp" Foreground="#333"/>
                                    </Button>
                                </Grid>

                                <Grid RowDefinitions="Auto" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="下一张图片" VerticalAlignment="Center"/>
                                    <Button x:Name="PageDownButton" Grid.Row="0" Grid.Column="2"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="8,6" Click="OnPageDownClick">
                                        <TextBlock x:Name="PageDownText" Text="PageDown" Foreground="#333"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 复制设置组 -->
                        <Border Background="#F9F9F9" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="编辑" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="对翻译文本进行操作" FontSize="12" Foreground="#666" TextWrapping="Wrap" Margin="0,-4,0,4"/>

                                <Grid RowDefinitions="Auto">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="复制文本" VerticalAlignment="Center"/>
                                    <Button x:Name="CopyTextButton" Grid.Row="0" Grid.Column="2"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="8,6" Click="OnCopyTextClick">
                                        <TextBlock x:Name="CopyTextText" Text="Ctrl + C" Foreground="#333"/>
                                    </Button>
                                </Grid>

                                <Grid RowDefinitions="Auto" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="删除标签" VerticalAlignment="Center"/>
                                    <Button x:Name="DeleteLabelButton" Grid.Row="0" Grid.Column="2"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="8,6" Click="OnDeleteLabelClick">
                                        <TextBlock x:Name="DeleteLabelText" Text="Delete" Foreground="#333"/>
                                    </Button>
                                </Grid>

                                <!-- 自动聚焦开关 -->
                                <Grid RowDefinitions="Auto" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="自动聚焦" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="AutoFocusCheckBox" Grid.Row="0" Grid.Column="2"
                                              IsChecked="True" VerticalAlignment="Center"
                                              Checked="OnAutoFocusChanged" Unchecked="OnAutoFocusChanged">
                                        <TextBlock Text="选中标签后自动聚焦到文本框" FontSize="12" Foreground="#666"/>
                                    </CheckBox>
                                </Grid>
                                <TextBlock Text="按 Ctrl+Enter 取消聚焦" FontSize="11" Foreground="#999" Margin="92,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- 文件设置组 -->
                        <Border Background="#F9F9F9" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="文件" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="打开和保存翻译文件" FontSize="12" Foreground="#666" TextWrapping="Wrap" Margin="0,-4,0,4"/>

                                <Grid RowDefinitions="Auto">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="打开文件" VerticalAlignment="Center"/>
                                    <Button x:Name="OpenFileButton" Grid.Row="0" Grid.Column="2"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="8,6" Click="OnOpenFileClick">
                                        <TextBlock x:Name="OpenFileText" Text="Ctrl + O" Foreground="#333"/>
                                    </Button>
                                </Grid>

                                <Grid RowDefinitions="Auto" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="保存文件" VerticalAlignment="Center"/>
                                    <Button x:Name="SaveFileButton" Grid.Row="0" Grid.Column="2"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="8,6" Click="OnSaveFileClick">
                                        <TextBlock x:Name="SaveFileText" Text="Ctrl + S" Foreground="#333"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 分组切换设置组 -->
                        <Border Background="#F9F9F9" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="分组切换" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="切换当前激活的分组（框内/框外）" FontSize="12" Foreground="#666" TextWrapping="Wrap" Margin="0,-4,0,4"/>

                                <Grid RowDefinitions="Auto">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="切换框内" VerticalAlignment="Center"/>
                                    <Button x:Name="ToggleGroup0Button" Grid.Row="0" Grid.Column="2"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="8,6" Click="OnToggleGroup0Click">
                                        <TextBlock x:Name="ToggleGroup0Text" Text="Ctrl + 1" Foreground="#333"/>
                                    </Button>
                                </Grid>

                                <Grid RowDefinitions="Auto" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="切换框外" VerticalAlignment="Center"/>
                                    <Button x:Name="ToggleGroup1Button" Grid.Row="0" Grid.Column="2"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="8,6" Click="OnToggleGroup1Click">
                                        <TextBlock x:Name="ToggleGroup1Text" Text="Ctrl + 2" Foreground="#333"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 重置按钮 -->
                        <Button Content="恢复默认设置" HorizontalAlignment="Left" Margin="0,8,0,0" Click="OnResetDefaults"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 颜色设置页签 -->
            <TabItem Header="界面">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12" Spacing="12">
                        <!-- 标号大小设置 -->
                        <TextBlock Text="标号显示设置" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        
                        <Border Background="#F9F9F9" CornerRadius="8" Padding="12">
                            <Grid RowDefinitions="Auto">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="标号大小" VerticalAlignment="Center"/>
                                <NumericUpDown x:Name="LabelSizeUpDown" Grid.Row="0" Grid.Column="2"
                                               Minimum="24" Maximum="128"
                                               FormatString="0"
                                               Increment="1"
                                               VerticalAlignment="Center"
                                               ValueChanged="OnLabelSizeChanged"/>
                            </Grid>
                        </Border>
                        
                        <TextBlock Text="标号颜色设置" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,8"/>
                        <TextBlock Text="自定义树状视图中标号的背景颜色和选中高亮颜色" FontSize="12" Foreground="#666" TextWrapping="Wrap" Margin="0,-4,0,8"/>

                        <!-- 框内颜色设置 -->
                        <Border Background="#F9F9F9" CornerRadius="8" Padding="12">
                            <Grid RowDefinitions="Auto">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="框内颜色" VerticalAlignment="Center"/>
                                <TextBox x:Name="Group0ColorTextBox" Grid.Row="0" Grid.Column="2"
                                         Watermark="#E74856" TextChanged="OnGroup0ColorChanged"
                                         VerticalAlignment="Center"/>
                                <Border x:Name="Group0ColorPreview" Grid.Row="0" Grid.Column="4"
                                        CornerRadius="4" Width="36" Height="24"
                                        Background="#E74856" BorderBrush="#CCC" BorderThickness="1"/>
                            </Grid>
                        </Border>

                        <!-- 框外颜色设置 -->
                        <Border Background="#F9F9F9" CornerRadius="8" Padding="12">
                            <Grid RowDefinitions="Auto">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="框外颜色" VerticalAlignment="Center"/>
                                <TextBox x:Name="Group1ColorTextBox" Grid.Row="0" Grid.Column="2"
                                         Watermark="#1E90FF" TextChanged="OnGroup1ColorChanged"
                                         VerticalAlignment="Center"/>
                                <Border x:Name="Group1ColorPreview" Grid.Row="0" Grid.Column="4"
                                        CornerRadius="4" Width="36" Height="24"
                                        Background="#1E90FF" BorderBrush="#CCC" BorderThickness="1"/>
                            </Grid>
                        </Border>

                        <!-- 选中高亮颜色设置 -->
                        <Border Background="#F9F9F9" CornerRadius="8" Padding="12">
                            <Grid RowDefinitions="Auto">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="选中高亮" VerticalAlignment="Center"/>
                                <TextBox x:Name="SelectedColorTextBox" Grid.Row="0" Grid.Column="2"
                                         Watermark="#33BA90" TextChanged="OnSelectedColorChanged"
                                         VerticalAlignment="Center"/>
                                <Border x:Name="SelectedColorPreview" Grid.Row="0" Grid.Column="4"
                                        CornerRadius="4" Width="36" Height="24"
                                        Background="#33BA90" BorderBrush="#CCC" BorderThickness="1"/>
                            </Grid>
                        </Border>

                        <!-- 颜色格式提示 -->
                        <TextBlock Text="提示：使用十六进制颜色代码" FontSize="11" Foreground="#999" Margin="0,4,0,0"/>

                        <!-- 重置按钮 -->
                        <Button Content="恢复默认颜色" HorizontalAlignment="Left" Margin="0,8,0,0" Click="OnResetColorDefaults"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 字体设置页签 -->
            <TabItem Header="字体">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12" Spacing="12">
                        <TextBlock Text="连字配置" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="选择连字配置以启用编辑器专用字体和 OpenType 连字特性" FontSize="12" Foreground="#666" TextWrapping="Wrap" Margin="0,-4,0,4"/>

                        <!-- 配置选择 -->
                        <Border Background="#F9F9F9" CornerRadius="8" Padding="12">
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="80,12,*">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="当前配置" VerticalAlignment="Center"/>
                                <ComboBox x:Name="DligConfigComboBox" Grid.Row="0" Grid.Column="2"
                                          SelectionChanged="OnDligConfigSelectionChanged"
                                          VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="字体家族" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                <TextBox x:Name="DligFontFamilyTextBox" Grid.Row="1" Grid.Column="2"
                                         Watermark="如 Source Han Sans"
                                         Margin="0,8,0,0" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="OpenType" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                <TextBox x:Name="DligFontFeaturesTextBox" Grid.Row="2" Grid.Column="2"
                                         Watermark="dlig=1"
                                         Margin="0,8,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- 快捷输入按钮 -->
                        <TextBlock Text="快捷输入按钮" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        <Border Background="#F9F9F9" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="4">
                                <ItemsControl x:Name="QuickInputSlotsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:QuickInputSlot">
                                            <Grid ColumnDefinitions="*,*" Margin="0,2">
                                                <TextBox Grid.Column="0" Text="{Binding Label}" Watermark="标签" Margin="0,0,4,0"/>
                                                <TextBox Grid.Column="1" Text="{Binding Character}" Watermark="字符" Margin="4,0,0,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- 操作按钮 -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button x:Name="NewDligConfigButton" Content="新建配置" Click="OnNewDligConfig"/>
                            <Button x:Name="DeleteDligConfigButton" Content="删除配置" Click="OnDeleteDligConfig"/>
                            <Button x:Name="OpenDligConfFolderButton" Content="打开配置目录" Click="OnOpenDligConfFolder"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
