<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:LabelAva.Views"
        xmlns:flua="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="LabelAva.Views.ImageSelectionWindow"
        Title="图片选择"
        Width="800" Height="500"
        Background="{DynamicResource SystemChromeMediumLowBrush}"
        TransparencyLevelHint="None"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
    
    <DockPanel Margin="16">
        <!-- 文件名输入区域 -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <TextBlock Text="文件名:" VerticalAlignment="Center" FontSize="14"/>
            <TextBox x:Name="FileNameTextBox" Width="250" FontSize="14" Watermark="输入文件名" TextChanged="OnFileNameTextChanged"/>
            <TextBlock Text=".txt" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource SystemControlForegroundChromeHighBrush}"/>
        </StackPanel>
        
        <!-- 底部按钮区域 -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <TextBlock Text="拖拽以重新排列图片顺序" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" HorizontalAlignment="Left" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                <Button x:Name="SelectAllButton" Content="全选" Click="OnSelectAll" MinWidth="80" Padding="12,8"/>
                <Button x:Name="DeselectAllButton" Content="全不选" Click="OnDeselectAll" MinWidth="80" Padding="12,8"/>
                <Button x:Name="ConfirmButton" Content="确认" Click="OnConfirm" Classes="primary" MinWidth="80" Padding="12,8"/>
                <Button x:Name="CancelButton" Content="取消" Click="OnCancel" MinWidth="80" Padding="12,8"/>
            </StackPanel>
        </StackPanel>
        
        <!-- 主内容区：左栏列表 + 右栏图片预览 -->
        <Grid ColumnDefinitions="250,*">
            <!-- 左栏：图片列表 -->
            <Panel Grid.Column="0" Margin="0,0,8,0">
                <Border BorderBrush="{DynamicResource SystemControlForegroundChromeHighBrush}" BorderThickness="1" CornerRadius="4">
                    <ListBox x:Name="ImageListControl" Margin="4" Background="Transparent" FontFamily="Sarasa Mono SC" FontSize="14" SelectionMode="Toggle" SelectionChanged="OnImageSelectionChanged">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="4,0"/>
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </ListBox.Styles>

                        <!-- <views:ImageSelectionItem FileName="1.png" IsSelected="True"/>
                        <views:ImageSelectionItem FileName="2.png" IsSelected="False"/>
                        <views:ImageSelectionItem FileName="3.jpg" IsSelected="True"/> -->

                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="views:ImageSelectionItem">
                                <Border Margin="0,0,0,0" Background="Transparent"
                                        PointerPressed="OnItemPointerPressed"
                                        PointerMoved="OnItemPointerMoved"
                                        PointerReleased="OnItemPointerReleased">
                                    <Grid RowDefinitions="*,Auto">
                                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                                            <flua:FluentIcon Grid.Column="0" Icon="ReOrderDotsVertical" FontSize="14" VerticalAlignment="Center"
                                                            Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding FileName}" VerticalAlignment="Center" FontSize="14" Margin="4,0"/>
                                            <CheckBox Grid.Column="2" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        </Grid>
                                        <Border Grid.Row="1" Height="1" Margin="0,0,4,0"
                                                Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Canvas x:Name="DropIndicatorCanvas" IsHitTestVisible="False">
                    <Rectangle x:Name="DropLine" Height="2" Fill="DodgerBlue" IsVisible="False"/>
                </Canvas>

                <Canvas x:Name="DragPreviewCanvas" IsHitTestVisible="False">
                    <Border x:Name="DragPreview" IsVisible="False" Opacity="0.7" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlForegroundChromeHighBrush}" BorderThickness="1" CornerRadius="2" Padding="4,2">
                        <TextBlock x:Name="DragPreviewText" FontSize="14"/>
                    </Border>
                </Canvas>
            </Panel>
            
            <!-- 右栏：图片预览 -->
            <Border Grid.Column="1" BorderBrush="{DynamicResource SystemControlForegroundChromeHighBrush}" BorderThickness="1" CornerRadius="4" Background="Transparent">
                <Panel>
                    <TextBlock Text="选择图片以预览" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseLowBrush}" FontSize="16"/>
                    <Image x:Name="PreviewImage" Stretch="Uniform" Margin="8"/>
                </Panel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
